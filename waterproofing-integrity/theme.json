{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "1200px",
      "wideSize": "1400px"
    },
    "color": {
      "custom": true,
      "customDuotone": false,
      "customGradient": false,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "palette": [
        {
          "slug": "navy",
          "color": "#1E3A5F",
          "name": "Navy"
        },
        {
          "slug": "blue",
          "color": "#2E86AB",
          "name": "Blue"
        },
        {
          "slug": "gold",
          "color": "#F0A500",
          "name": "Gold"
        },
        {
          "slug": "orange",
          "color": "#F5620F",
          "name": "Orange"
        },
        {
          "slug": "light-grey",
          "color": "#F2F2F2",
          "name": "Light Grey"
        },
        {
          "slug": "white",
          "color": "#FFFFFF",
          "name": "White"
        },
        {
          "slug": "muted",
          "color": "#6B7E9A",
          "name": "Muted"
        },
        {
          "slug": "border",
          "color": "#E0E0E0",
          "name": "Border"
        }
      ]
    },
    "typography": {
      "customFontSize": true,
      "defaultFontSizes": false,
      "fontFamilies": [
        {
          "name": "Raleway",
          "slug": "raleway",
          "fontFamily": "'Raleway', sans-serif",
          "fontFace": []
        },
        {
          "name": "System UI",
          "slug": "system-ui",
          "fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif"
        }
      ],
      "fontSizes": [
        {
          "slug": "sm",
          "size": "0.875rem",
          "name": "Small"
        },
        {
          "slug": "base",
          "size": "1rem",
          "name": "Base"
        },
        {
          "slug": "lg",
          "size": "1.125rem",
          "name": "Large"
        },
        {
          "slug": "xl",
          "size": "clamp(1.125rem, 2vw, 1.375rem)",
          "name": "X-Large"
        },
        {
          "slug": "2xl",
          "size": "clamp(1.5rem, 3.5vw, 2.25rem)",
          "name": "2X-Large"
        },
        {
          "slug": "3xl",
          "size": "clamp(1.875rem, 5vw, 3rem)",
          "name": "3X-Large"
        }
      ]
    },
    "spacing": {
      "customSpacingSize": true,
      "defaultSpacingSizes": false,
      "spacingSizes": [
        { "slug": "xs",  "size": "0.5rem",  "name": "XS" },
        { "slug": "sm",  "size": "1rem",    "name": "SM" },
        { "slug": "md",  "size": "1.5rem",  "name": "MD" },
        { "slug": "lg",  "size": "2rem",    "name": "LG" },
        { "slug": "xl",  "size": "3rem",    "name": "XL" },
        { "slug": "2xl", "size": "5rem",    "name": "2XL" },
        { "slug": "3xl", "size": "7rem",    "name": "3XL" }
      ],
      "units": ["px", "em", "rem", "%", "vh", "vw"]
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        {
          "slug": "card",
          "shadow": "0 1px 2px 0 rgba(30, 58, 95, 0.05)",
          "name": "Card"
        },
        {
          "slug": "card-md",
          "shadow": "0 4px 6px -1px rgba(30, 58, 95, 0.08), 0 2px 4px -2px rgba(30, 58, 95, 0.06)",
          "name": "Card MD"
        },
        {
          "slug": "card-hover",
          "shadow": "0 10px 15px -3px rgba(30, 58, 95, 0.10), 0 4px 6px -4px rgba(30, 58, 95, 0.08)",
          "name": "Card Hover"
        },
        {
          "slug": "nav",
          "shadow": "0 2px 12px rgba(30, 58, 95, 0.15)",
          "name": "Nav"
        }
      ]
    },
    "blocks": {
      "core/button": {
        "color": {
          "palette": [
            { "slug": "navy",  "color": "#1E3A5F", "name": "Navy" },
            { "slug": "gold",  "color": "#F0A500", "name": "Gold" },
            { "slug": "white", "color": "#FFFFFF",  "name": "White" }
          ]
        }
      }
    }
  },
  "styles": {
    "color": {
      "background": "#FFFFFF",
      "text": "#1E3A5F"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--system-ui)",
      "fontSize": "var(--wp--preset--font-size--base)",
      "lineHeight": "1.6"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--lg)"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--raleway)",
          "fontSize": "clamp(1.875rem, 5vw, 3rem)",
          "fontWeight": "800",
          "lineHeight": "1.15"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--raleway)",
          "fontSize": "clamp(1.5rem, 3.5vw, 2.25rem)",
          "fontWeight": "700",
          "lineHeight": "1.15"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--raleway)",
          "fontSize": "clamp(1.125rem, 2vw, 1.375rem)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "h4": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--raleway)",
          "fontSize": "0.875rem",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "h5": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--raleway)",
          "fontWeight": "600"
        }
      },
      "h6": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--raleway)",
          "fontWeight": "600"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--blue)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--navy)"
          }
        }
      }
    }
  },
  "templateParts": [
    {
      "name": "header",
      "title": "Header",
      "area": "header"
    },
    {
      "name": "footer",
      "title": "Footer",
      "area": "footer"
    },
    {
      "name": "proof-ticker",
      "title": "Proof Ticker",
      "area": "uncategorized"
    }
  ],
  "patterns": []
}
